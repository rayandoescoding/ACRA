# Docker Compose local environment only. Copy to `.env`; do not use this file
# for a managed production deployment. See DEPLOYMENT.md for production values.

# PostgreSQL (the Docker Compose service)
POSTGRES_DB=acra
POSTGRES_USER=acra
POSTGRES_PASSWORD=replace-with-a-local-database-password
POSTGRES_PORT=5432

# Backend (the Docker Compose service)
APP_NAME=ACRA
APP_VERSION=0.1.0
ENVIRONMENT=docker
DEBUG=false
BACKEND_PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]
JWT_SECRET_KEY=replace-with-a-long-random-local-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-local-password
DEMO_SEED_ENABLED=true

# Frontend (embedded at image build time)
FRONTEND_PORT=3000
NEXT_PUBLIC_ACRA_API_BASE_URL=http://localhost:8000/api/v1
