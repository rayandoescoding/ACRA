# Local backend development only. Copy to `backend/.env` when running outside
# Docker Compose. Use the provider environment settings and
# `backend/.env.production.example` for production guidance.

# Application configurations
APP_NAME="ACRA Backend"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
DEBUG=true

# Server configuration
HOST="127.0.0.1"
PORT=8000

# CORS configurations (JSON format array of allowed origin strings)
ALLOWED_ORIGINS='["http://localhost:3000", "http://127.0.0.1:8000"]'

# Database configuration
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/acra"

# Authentication (local development only; never deploy this placeholder)
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional one-time initial administrator bootstrap. Remove after first startup.
AUTH_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
AUTH_BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-strong-one-time-password"

# Demo data (creates the idempotent pipeline demonstration dataset on startup)
DEMO_SEED_ENABLED=true
