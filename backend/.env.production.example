# Production backend reference only. Configure these values in the deployment
# provider; do not copy this file to a tracked environment file.
APP_NAME=ACRA
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# JSON array containing the exact deployed frontend origin, with no trailing slash.
ALLOWED_ORIGINS=["https://your-project.vercel.app"]

# Managed PostgreSQL async SQLAlchemy connection string. Percent-encode any
# reserved characters in the username or password.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<database>?ssl=require

# Generate a long random value and store it only in the provider secret manager.
JWT_SECRET_KEY=<generate-a-long-random-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional, one-time initial administrator bootstrap. Remove both values after
# the account has been created.
AUTH_BOOTSTRAP_ADMIN_EMAIL=<initial-admin-email>
AUTH_BOOTSTRAP_ADMIN_PASSWORD=<strong-one-time-password>

# Keep demo data disabled in production unless an intentional demonstration is required.
DEMO_SEED_ENABLED=false
